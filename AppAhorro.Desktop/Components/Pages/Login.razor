@page "/"
@using AppAhorro.Backend.Services
@using AppAhorro.Backend.Models
@inject UsuarioService UsuarioService
@inject NavigationManager Navigation

<div class="login-container">
    <div class="login-card">
        <h2>Ahorradito</h2>
        <p class="subtitle">Gestiona tus finanzas con inteligencia</p>

        <div class="form-group">
            <label>Nombre de Usuario</label>
            <input type="text" class="form-control" placeholder="Ej. Gabriel" @bind="usuarioInput" />
        </div>

        <div class="form-group">
            <label>Contraseña</label>
            <input type="password" class="form-control" placeholder="******" @bind="passwordInput" />
        </div>

        <div class="button-group">
            <button class="btn btn-primary" @onclick="ProcesarLogin">Iniciar Sesión</button>
            <button class="btn btn-secondary" @onclick="ProcesarRegistro">Registrarse</button>
        </div>

        @if (!string.IsNullOrEmpty(mensajeFeedback))
        {
            <div class="alert @(esError ? "alert-danger" : "alert-success")">
                @mensajeFeedback
            </div>
        }
    </div>
</div>

@code {
    private string usuarioInput = "";
    private string passwordInput = "";
    private string mensajeFeedback = "";
    private bool esError = false;

    private void ProcesarLogin()
    {
        Usuario? user = UsuarioService.IniciarSesion(usuarioInput, passwordInput);
        
        if (user != null)
        {
            esError = false;
            mensajeFeedback = $"¡Bienvenido de nuevo, {user.NombreUsuario}!";
        }
        else
        {
            esError = true;
            mensajeFeedback = "Error: Credenciales incorrectas o campos vacíos.";
        }
    }

    private void ProcesarRegistro()
    {
        string resultado = UsuarioService.RegistrarNuevoUsuario(usuarioInput, passwordInput);
        
        if (resultado.StartsWith("Error"))
        {
            esError = true;
            mensajeFeedback = resultado;
        }
        else
        {
            esError = false;
            mensajeFeedback = resultado;
        }
    }
}

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 85vh;
        background-color: #121214;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .login-card {
        background-color: #1a1a1e;
        padding: 2.5rem;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
        width: 100%;
        max-width: 400px;
        color: #ffffff;
        text-align: center;
    }

    h2 {
        color: #4ade80;
        margin-bottom: 0.5rem;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .subtitle {
        color: #9ca3af;
        font-size: 0.9rem;
        margin-bottom: 2rem;
    }

    .form-group {
        text-align: left;
        margin-bottom: 1.5rem;
    }

    label {
        display: block;
        color: #e5e7eb;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .form-control {
        width: 100%;
        padding: 0.75rem;
        background-color: #26262b;
        border: 1px solid #3f3f46;
        border-radius: 6px;
        color: #fff;
        font-size: 1rem;
        transition: border-color 0.2s;
    }

    .form-control:focus {
        outline: none;
        border-color: #4ade80;
    }

    .button-group {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn {
        flex: 1;
        padding: 0.75rem;
        border: none;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .btn-primary {
        background-color: #4ade80;
        color: #000;
    }

    .btn-primary:hover {
        background-color: #22c55e;
    }

    .btn-secondary {
        background-color: #3f3f46;
        color: #fff;
    }

    .btn-secondary:hover {
        background-color: #52525b;
    }

    .alert {
        margin-top: 1.5rem;
        padding: 0.75rem;
        border-radius: 6px;
        font-size: 0.9rem;
    }

    .alert-danger {
        background-color: #ef444422;
        color: #f87171;
        border: 1px solid #ef444444;
    }

    .alert-success {
        background-color: #22c55e22;
        color: #4ade80;
        border: 1px solid #22c55e44;
    }
</style>